{
  "name": "logly-backend",
  "version": "0.1.0",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "predev": "npm run build:sdk",
    "build": "tsc",
    "prebuild": "npm run build:sdk",
    "build:sdk": "node scripts/build-sdk.mjs",
    "start": "node dist/index.js",
    "worker": "ts-node src/jobs/worker.ts",
    "test": "node -r ts-node/register --test src/lib/__tests__/*.test.ts",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^6.9.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.14",
    "esbuild": "^0.28.1",
    "nodemon": "^3.0.0",
    "prisma": "^5.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5"
  }
}
